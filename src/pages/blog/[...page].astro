---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MagazineCard from '../../components/MagazineCard.astro';
import Pagination from '../../components/Pagination.astro';
import { toTime } from '../../utils/date';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort(
    (a, b) => toTime(b.data.date) - toTime(a.data.date)
  );

  const pages = [];
  const pageSize = 12;
  const totalPages = Math.max(1, Math.ceil(posts.length / pageSize));

  for (let i = 0; i < totalPages; i++) {
    const pageNum = i + 1;
    const isFirst = i === 0;
    pages.push({
      params: { page: isFirst ? undefined : String(pageNum) },
      props: {
        page: {
          data: posts.slice(i * pageSize, (i + 1) * pageSize),
          currentPage: pageNum,
          lastPage: totalPages,
          url: {
            prev: isFirst ? undefined : (pageNum === 2 ? '/blog/' : `/blog/${pageNum - 1}/`),
            next: pageNum < totalPages ? `/blog/${pageNum + 1}/` : undefined,
          },
        },
      },
    });
  }
  return pages;
}

const { page } = Astro.props;
const isFirst = page.currentPage === 1;
---

<Layout
  title={isFirst ? 'Blog' : `Blog · Page ${page.currentPage}`}
  description="Latest stories, news and ideas from Infeeds."
>
  <main class="content">
    <div class="container mag-grid-page">
      <div class="section-mag">
        <div class="section-mag__head">
          <div>
            <span class="section-mag__kicker">Archive</span>
            <h1 class="section-mag__title">{isFirst ? 'Latest stories' : `Page ${page.currentPage}`}</h1>
          </div>
          <span class="section-mag__link">Page {page.currentPage} of {page.lastPage}</span>
        </div>
        <div class="cat-section__row">
          {page.data.map((post: any) => (
            <MagazineCard post={post} variant="grid" />
          ))}
        </div>
      </div>

      <Pagination page={page} baseUrl="/blog/" />
    </div>
  </main>
</Layout>