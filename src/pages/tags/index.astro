---
// Tag-cloud index: every topic used across the site, sized by post count.
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('posts');
const counts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const t = String(tag);
    counts.set(t, (counts.get(t) ?? 0) + 1);
  }
}
const tags = [...counts.entries()]
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag));
const max = Math.max(...tags.map((t) => t.count), 1);
---

<Layout title="All topics" description="Browse every topic on Infeeds.">
  <main class="content">
    <div class="container mag-grid-page">
      <div class="section-mag">
        <div class="section-mag__head">
          <div>
            <span class="section-mag__kicker">Explore</span>
            <h1 class="section-mag__title">All topics</h1>
          </div>
          <span class="section-mag__link">{tags.length} topics</span>
        </div>
        <div class="all-tags-cloud">
          {tags.map(({ tag, count }) => {
            const size = 13 + Math.round((count / max) * 7);
            const slug = String(tag).toLowerCase().replace(/\s+/g, '-');
            return (
              <a
                href={`/tags/${slug}/`}
                class="all-tags-cloud__item"
                style={`font-size: ${size}px;`}
              >
                {tag}
                <span class="all-tags-cloud__count">{count}</span>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </main>
</Layout>