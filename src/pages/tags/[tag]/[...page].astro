---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Pagination from '../../../components/Pagination.astro';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  
  const tags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort();

  const pages = [];
  const regularPageSize = 12;

  tags.forEach(tag => {
    const postsWithTag = allPosts
      .filter((post) => post.data.tags?.includes(tag));

    const totalPosts = postsWithTag.length;
    const lastPage = Math.ceil(totalPosts / regularPageSize);

    let currentPos = 0;
    let pageNum = 1;

    // Use Astro's standard slugification for URL construction
    const safeTagSlug = tag.toLowerCase().replace(/\s+/g, '-');

    while (currentPos < totalPosts) {
      const endPos = currentPos + regularPageSize;
      
      pages.push({
        params: { 
          tag: safeTagSlug,
          page: pageNum === 1 ? undefined : pageNum.toString()
        },
        props: {
          tag: tag,
          page: {
            data: postsWithTag.slice(currentPos, endPos),
            currentPage: pageNum,
            lastPage: lastPage,
            totalPosts: totalPosts,
            url: {
              prev: pageNum === 1 ? undefined : (pageNum === 2 ? `/tags/${safeTagSlug}/` : `/tags/${safeTagSlug}/${pageNum - 1}/`),
              next: endPos < totalPosts ? `/tags/${safeTagSlug}/${pageNum + 1}/` : undefined
            }
          }
        }
      });
      currentPos = endPos;
      pageNum++;
    }
  });

  return pages;
}

const { page, tag } = Astro.props;

const siteUrl = (Astro.site?.toString() || 'https://infeeds.com').replace(/\/$/, '');
const safeTagSlug = String(tag).toLowerCase().replace(/\s+/g, '-');
const isFirstPage = page.currentPage === 1;
const tagUrl = isFirstPage
  ? `${siteUrl}/tags/${safeTagSlug}/`
  : `${siteUrl}/tags/${safeTagSlug}/${page.currentPage}/`;
const tagLabel = `${tag} posts on Infeeds`;
const tagDescription = `Latest ${tag.toLowerCase()} stories, news, and ideas from Infeeds. ${page.totalPosts} ${page.totalPosts === 1 ? 'post' : 'posts'} tagged ${tag}.`;

// JSON-LD: CollectionPage for the tag landing page + BreadcrumbList.
// We only emit structured data on the first page to avoid duplicate-content signals.
const collectionPageJsonLd = isFirstPage ? {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': tagUrl,
  url: tagUrl,
  name: tagLabel,
  description: tagDescription,
  inLanguage: 'en',
  isPartOf: { '@id': `${siteUrl}#website` },
  about: tag,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: page.totalPosts,
    itemListElement: page.data.slice(0, 10).map((post: any, index: number) => {
      const slug = post.id.replace(/^\d{4}-\d{2}-\d{2}-/, '').replace(/\.(md|markdown|mdx)$/, '');
      return {
        '@type': 'ListItem',
        position: index + 1,
        url: `${siteUrl}/${slug}/`,
        name: post.data.title,
      };
    }),
  },
} : null;

const breadcrumbJsonLd = isFirstPage ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Tags', item: `${siteUrl}/tags/` },
    { '@type': 'ListItem', position: 3, name: tag, item: tagUrl },
  ],
} : null;
---

<Layout title={tagLabel} description={tagDescription}>
  {collectionPageJsonLd && (
    <Fragment slot="jsonld">
      <script type="application/ld+json" set:html={JSON.stringify(collectionPageJsonLd)} />
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    </Fragment>
  )}
  <div class="container tags__inner">
    <div class="row">
      <div class="col col-12">
        <div class="tag__info">
          <div class="tag__counter">
            {page.totalPosts} {page.totalPosts === 1 ? 'Post' : 'Posts'}
          </div>
          <h2 class="tag__name">{tag}</h2>
        </div>
      </div>
    </div>

    <div class="row">
      {page.data.map((post: any, index: number) => (
        <ArticleCard post={post} index={index} />
      ))}
    </div>

    <Pagination page={page} baseUrl={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`} />
  </div>
</Layout>