---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import MagazineCard from '../../../components/MagazineCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCleanSlug } from '../../../utils/slug';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  const tags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort();
  const pages = [];
  const pageSize = 12;

  tags.forEach((tag) => {
    const postsWithTag = allPosts.filter((post) => (post.data.tags || []).includes(tag));
    if (!postsWithTag.length) return;
    const totalPages = Math.max(1, Math.ceil(postsWithTag.length / pageSize));
    const safeTagSlug = String(tag).toLowerCase().replace(/\s+/g, '-');

    for (let i = 0; i < totalPages; i++) {
      const pageNum = i + 1;
      const isFirst = i === 0;
      pages.push({
        params: {
          tag: safeTagSlug,
          page: isFirst ? undefined : String(pageNum),
        },
        props: {
          tag,
          page: {
            data: postsWithTag.slice(i * pageSize, (i + 1) * pageSize),
            currentPage: pageNum,
            lastPage: totalPages,
            totalPosts: postsWithTag.length,
            url: {
              prev: isFirst ? undefined : (pageNum === 2 ? `/tags/${safeTagSlug}/` : `/tags/${safeTagSlug}/${pageNum - 1}/`),
              next: pageNum < totalPages ? `/tags/${safeTagSlug}/${pageNum + 1}/` : undefined,
            },
          },
        },
      });
    }
  });

  return pages;
}

const { page, tag } = Astro.props;
const isFirst = page.currentPage === 1;
const safeTagSlug = String(tag).toLowerCase().replace(/\s+/g, '-');
const display = String(tag).charAt(0).toUpperCase() + String(tag).slice(1).toLowerCase();
const tagUrl = isFirst ? `/tags/${safeTagSlug}/` : `/tags/${safeTagSlug}/${page.currentPage}/`;
const tagDescription = `Latest ${String(tag).toLowerCase()} stories, news, and ideas from Infeeds. ${page.totalPosts} ${page.totalPosts === 1 ? 'post' : 'posts'} tagged ${tag}.`;
---

<Layout title={`${display} posts`} description={tagDescription}>
  <main class="content">
    <div class="container mag-grid-page">
      <div class="section-mag">
        <div class="section-mag__head">
          <div>
            <span class="section-mag__kicker">Topic</span>
            <h1 class="section-mag__title">{display}</h1>
          </div>
          <span class="section-mag__link">{page.totalPosts} {page.totalPosts === 1 ? 'post' : 'posts'}</span>
        </div>
        <div class="cat-section__row">
          {page.data.map((post: any) => (
            <MagazineCard post={post} variant="grid" />
          ))}
        </div>
      </div>

      <Pagination page={page} baseUrl={isFirst ? `/tags/${safeTagSlug}/` : `/tags/${safeTagSlug}/`} />
    </div>
  </main>
</Layout>