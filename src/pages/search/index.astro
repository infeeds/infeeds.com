---
// Title-only search. SSG pages can't read query params at build time, so the
// query string is parsed on the client.
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Search" description="Search Infeeds by title or tag.">
  <main class="content">
    <div class="container">
      <article class="post-mag" style="margin-top: 16px;">
        <h1 class="post-mag__title">Search</h1>
        <p class="post-mag__deck">Search posts by title or tag. We index titles and tags only.</p>
        <form class="search-box" id="search-form" method="get" action="/search/">
          <span class="search-box__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </span>
          <input
            id="search-q"
            type="search"
            name="q"
            placeholder="Search articles..."
            aria-label="Search"
            autofocus
          />
          <button type="submit">Search</button>
        </form>
        <div id="search-results"></div>
      </article>
    </div>
  </main>
</Layout>

<script is:inline>
  // Read the query from the URL on the client (SSG pages can't see ?q= at build).
  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q') || '';
  const input = document.getElementById('search-q');
  const form = document.getElementById('search-form');
  const host = document.getElementById('search-results');

  if (input && initialQuery) input.value = initialQuery;

  let INDEX = null;

  const score = (entry, needle) => {
    const t = (entry.t || '').toLowerCase();
    const tags = (entry.g || []).join(' ').toLowerCase();
    const ex = (entry.e || '').toLowerCase();
    if (t.includes(needle)) return 3;
    if (tags.includes(needle)) return 2;
    if (ex.includes(needle)) return 1;
    return 0;
  };

  const escapeHtml = (s) => String(s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');

  const render = (entries, q) => {
    if (!q) {
      host.innerHTML = '<div class="search-results__empty">Type a query to search.</div>';
      return;
    }
    if (!entries.length) {
      host.innerHTML = '<div class="search-results__empty">No results for &ldquo;' + escapeHtml(q) + '&rdquo;. Try a different term.</div>';
      return;
    }
    host.innerHTML = '<p style="font-size:13px;color:var(--text-alt-color);margin:0 0 8px;">' + entries.length + ' result' + (entries.length === 1 ? '' : 's') + '</p>' +
      entries.map((e) => {
        const tag = (e.g && e.g[0]) ? '<span class="search-result__tag">' + escapeHtml(e.g[0]) + '</span>' : '';
        const img = e.i ? '<div class="search-result__image"><img src="' + escapeHtml(e.i) + '" alt="" loading="lazy" /></div>' : '<div></div>';
        return '<a class="search-result" href="' + escapeHtml(e.u) + '">' + img +
          '<div>' + tag +
            '<h3 class="search-result__title">' + escapeHtml(e.t) + '</h3>' +
            (e.e ? '<p class="search-result__excerpt">' + escapeHtml(e.e) + '</p>' : '') +
          '</div></a>';
      }).join('');
  };

  const run = async (q) => {
    if (!INDEX) {
      try {
        const res = await fetch('/search-index.json');
        INDEX = await res.json();
      } catch (e) {
        host.innerHTML = '<div class="search-results__empty">Search index unavailable.</div>';
        return;
      }
    }
    const needle = q.toLowerCase().trim();
    if (!needle) { render([], ''); return; }
    const scored = [];
    for (const entry of INDEX) {
      const s = score(entry, needle);
      if (s > 0) scored.push({ s, entry });
    }
    scored.sort((a, b) => b.s - a.s || (b.entry.d || '').localeCompare(a.entry.d || ''));
    render(scored.slice(0, 50).map((x) => x.entry), q);
  };

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const v = input.value.trim();
    const u = new URL(location.href);
    if (v) u.searchParams.set('q', v);
    else u.searchParams.delete('q');
    history.replaceState(null, '', u.toString());
    run(v);
  });

  let timer;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(() => {
      const u = new URL(location.href);
      if (input.value) u.searchParams.set('q', input.value);
      else u.searchParams.delete('q');
      history.replaceState(null, '', u.toString());
      run(input.value);
    }, 120);
  });

  run(initialQuery);
</script>