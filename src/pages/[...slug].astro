---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { settings } from '../data/settings';
import { getCleanSlug, getDateFromFilename } from '../utils/slug';
import { toTime, formatDate } from '../utils/date';
import AdUnit from '../components/AdUnit.astro';
import SocialShare from '../components/SocialShare.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import ReadingProgress from '../components/ReadingProgress.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const pages = await getCollection('pages');

  const postPaths = posts.map((post) => ({
    params: { slug: getCleanSlug(post.id) },
    props: { entry: post, type: 'post' },
  }));

  const pagePaths = pages.map((page) => ({
    params: { slug: page.id },
    props: { entry: page, type: 'page' },
  }));

  return [...postPaths, ...pagePaths];
}

const { entry, type } = Astro.props;
// Narrow `data` to Post fields when type==='post'. The static-paths
// distribution above gives us two distinct entry shapes; we want post
// fields accessible without `?.` chains.
const data = type === 'post' ? (entry.data as any) : (entry.data as any);
const { Content } = await render(entry as any);

const authorEntry = type === 'post' ? await getEntry('authors', (data as any).author) : null;
const author = authorEntry?.data;

const rawDate = (data as any).date ?? getDateFromFilename(entry.id);
const formattedDate = rawDate ? new Date(rawDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}) : '';

const siteUrl = (Astro.site?.toString() || 'https://infeeds.com').replace(/\/$/, '');
const currentUrl = `${siteUrl}/${getCleanSlug(entry.id)}/`;
const isoDate = rawDate ? new Date(rawDate).toISOString() : null;

// Page-specific JSON-LD: BlogPosting + BreadcrumbList for posts.
// We don't emit JSON-LD for static pages; the site-wide Organisation/WebSite
// from Layout covers them.
const blogPostingJsonLd = type === 'post' ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${currentUrl}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': currentUrl },
  headline: data.title,
  description: data.description || '',
  ...(data.image ? { image: [new URL(data.image, siteUrl).toString()] } : {}),
  datePublished: isoDate,
  dateModified: isoDate,
  author: author ? {
    '@type': 'Person',
    name: author.name,
    url: `${siteUrl}/author/${author.username}/`,
  } : { '@type': 'Organization', name: settings.author.name, url: siteUrl },
  publisher: { '@id': `${siteUrl}#organization` },
  articleSection: data.tags?.[0] ?? 'Lifestyle',
  keywords: (data.tags ?? []).join(', '),
} : null;

const primaryTag = data.tags?.[0];
const breadcrumbJsonLd = type === 'post' ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
    ...(primaryTag ? [{
      '@type': 'ListItem',
      position: 3,
      name: primaryTag,
      item: `${siteUrl}/tags/${String(primaryTag).toLowerCase().replace(/\s+/g, '-')}/`,
    }] : []),
    { '@type': 'ListItem', position: primaryTag ? 4 : 3, name: data.title, item: currentUrl },
  ],
} : null;
---

<Layout title={data.title} description={data.description} image={data.image} ogType="article">
  <ReadingProgress />

  {blogPostingJsonLd && (
    <Fragment slot="jsonld">
      <script type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />
    </Fragment>
  )}
  {breadcrumbJsonLd && (
    <Fragment slot="jsonld">
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    </Fragment>
  )}
  {type === 'post' ? (
    <div class="container">
      <article class="post-mag">
        <div class={`post-mag__info ${data.video_embed ? 'post-mag__info--video' : ''}`}>
          {data.tags && data.tags.length > 0 && (
            <div class="post-mag__tags">
              {data.tags.map((tag: string) => (
                <a
                  href={`/tags/${String(tag).toLowerCase().replace(/\s+/g, '-')}/`}
                  class="post-mag__tag"
                  style={data.tags_color ? { backgroundColor: data.tags_color, color: '#fff' } : {}}
                >
                  {tag}
                </a>
              ))}
            </div>
          )}

          <h1 class="post-mag__title">{data.title}</h1>

          {data.description && <p class="post-mag__deck">{data.description}</p>}

          <div class="post-mag__byline">
            {author?.image && (
              <img
                class="post-mag__avatar"
                src={author.image}
                alt={author.name}
                loading="lazy"
                decoding="async"
                width="28"
                height="28"
              />
            )}
            <span>By <strong>{author?.name || settings.author.name}</strong></span>
            {rawDate && (
              <>
                <span>&middot;</span>
                <time datetime={new Date(rawDate).toISOString()}>{formattedDate}</time>
              </>
            )}
          </div>
        </div>

        {data.video_embed ? (
          <div class="post-video">
            <div class="post-video__wrap">
              <iframe src={data.video_embed} loading="lazy" width="640" height="360" allowfullscreen></iframe>
            </div>
          </div>
        ) : data.image && (
          <div class="post-mag__hero-image">
            <img
              src={data.image}
              alt={data.title}
              loading="eager"
              decoding="async"
              width="1200"
              height="720"
            />
          </div>
        )}
      </article>
    </div>
  ) : (
    <div class="container">
      <article class="post-mag">
        <h1 class="post-mag__title">{data.title}</h1>
      </article>
    </div>
  )}

  <div class="container">
    <div class="post-mag__layout-grid">
      <div>
        <article class="post-mag__body">
          <Content />

          {type === 'post' && (
            <div class="post-mag__end">
              <div class="post-mag__end-tags">
                {data.tags && data.tags.length > 0 && (
                  <>
                    <span class="post-mag__end-label">Filed under</span>
                    <div class="tag-cloud post-mag__end-tags-list">
                      {data.tags.map((tag: string) => (
                        <a href={`/tags/${String(tag).toLowerCase().replace(/\s+/g, '-')}/`}>{tag}</a>
                      ))}
                    </div>
                  </>
                )}
              </div>
              <SocialShare
                title={data.title}
                url={currentUrl}
                image={data.image}
                description={data.description}
                siteTitle={settings.title}
              />
            </div>
          )}
        </article>
      </div>

      <aside class="post-mag__aside" aria-label="Post sidebar">
        {type === 'post' && data.tags && (
          <RelatedPosts currentPostId={entry.id} tags={data.tags} count={6} />
        )}
        <AdUnit location="sidebar_ad" context="blog" />
      </aside>
    </div>
  </div>
</Layout>