---
// Paginated author pages: /author/<x>/, /author/<x>/2/, /author/<x>/3/, ...
// Catch-all [...page] matches the first page (page === undefined) and every
// numbered page thereafter, so we don't fight Astro's router like the old
// [username].astro did.
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import AuthorPostsView from '../../../components/AuthorPostsView.astro';
import { toTime } from '../../../utils/date';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  const posts = await getCollection('posts');

  const pageSize = 12;
  const paths: any[] = [];

  for (const author of authors) {
    const authorPosts = posts
      .filter((post) => post.data.author === author.data.username)
      .sort((a, b) => toTime(b.data.date) - toTime(a.data.date));

    if (authorPosts.length === 0) continue;
    const totalPages = Math.max(1, Math.ceil(authorPosts.length / pageSize));

    for (let i = 1; i < totalPages; i++) {
      // Skip page 1 — it's emitted by the file route at
      // /author/[username].astro. Catch-all only emits pages 2+.
      const pageNum = i + 1;
      paths.push({
        params: { username: author.data.username, page: String(pageNum) },
        props: {
          author: author.data,
          authorBody: author.body,
          page: {
            data: authorPosts.slice(i * pageSize, (i + 1) * pageSize),
            currentPage: pageNum,
            lastPage: totalPages,
            totalPosts: authorPosts.length,
            url: {
              prev: pageNum === 2
                ? `/author/${author.data.username}/`
                : `/author/${author.data.username}/${pageNum - 1}/`,
              next: pageNum < totalPages
                ? `/author/${author.data.username}/${pageNum + 1}/`
                : undefined,
            },
          },
        },
      });
    }
  }

  return paths;
}

const { author, authorBody, page } = Astro.props as any;
const isFirst = page.currentPage === 1;

const siteUrl = (Astro.site?.toString() || 'https://infeeds.com').replace(/\/$/, '');
const authorUrl = `${siteUrl}/author/${author.username}/`;
const sameAs: string[] = [];
if (author.twitter) sameAs.push(author.twitter);
if (author.facebook) sameAs.push(author.facebook);
if (author.website) sameAs.push(author.website);

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${authorUrl}#person`,
  name: author.name,
  url: authorUrl,
  ...(author.image ? { image: new URL(author.image, siteUrl).toString() } : {}),
  ...(author.location ? { homeLocation: author.location } : {}),
  ...(sameAs.length ? { sameAs } : {}),
  worksFor: { '@id': `${siteUrl}#organization` },
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: author.name, item: authorUrl },
  ],
};
---

<Layout
  title={isFirst ? author.name : `${author.name} · Page ${page.currentPage}`}
  description={authorBody}
  image={author.image}
>
  <Fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <main class="content">
    <div class="container mag-grid-page">
      <AuthorPostsView
        author={author}
        authorBody={authorBody}
        page={page}
        baseUrl={`/author/${author.username}/`}
      />
    </div>
  </main>
</Layout>
