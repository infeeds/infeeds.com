---
// Author first page: /author/<x>/
// Subsequent pages (2, 3, …) are emitted by the catch-all at
// /author/[username]/[...page].astro. Both routes share the render
// component AuthorPostsView.astro.
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AuthorPostsView from '../../components/AuthorPostsView.astro';
import { toTime } from '../../utils/date';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  const posts = await getCollection('posts');
  const pageSize = 12;

  return authors
    .map((author) => {
      const authorPosts = posts
        .filter((post) => post.data.author === author.data.username)
        .sort((a, b) => toTime(b.data.date) - toTime(a.data.date));
      if (authorPosts.length === 0) return null;
      const totalPages = Math.max(1, Math.ceil(authorPosts.length / pageSize));
      return { author, authorPosts, totalPages };
    })
    .filter((x): x is { author: any; authorPosts: any[]; totalPages: number } => x !== null)
    .map(({ author, authorPosts, totalPages }) => ({
      params: { username: author.data.username },
      props: {
        author: author.data,
        authorBody: author.body,
        page: {
          data: authorPosts.slice(0, pageSize),
          currentPage: 1,
          lastPage: totalPages,
          totalPosts: authorPosts.length,
          url: {
            prev: undefined,
            next: totalPages > 1 ? `/author/${author.data.username}/2/` : undefined,
          },
        },
      },
    }));
}

const { author, authorBody, page } = Astro.props as any;

const siteUrl = (Astro.site?.toString() || 'https://infeeds.com').replace(/\/$/, '');
const authorUrl = `${siteUrl}/author/${author.username}/`;
const sameAs: string[] = [];
if (author.twitter) sameAs.push(author.twitter);
if (author.facebook) sameAs.push(author.facebook);
if (author.website) sameAs.push(author.website);

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${authorUrl}#person`,
  name: author.name,
  url: authorUrl,
  ...(author.image ? { image: new URL(author.image, siteUrl).toString() } : {}),
  ...(author.location ? { homeLocation: author.location } : {}),
  ...(sameAs.length ? { sameAs } : {}),
  worksFor: { '@id': `${siteUrl}#organization` },
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: author.name, item: authorUrl },
  ],
};
---

<Layout
  title={author.name}
  description={authorBody}
  image={author.image}
>
  <Fragment slot="jsonld">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <main class="content">
    <div class="container mag-grid-page">
      <AuthorPostsView
        author={author}
        authorBody={authorBody}
        page={page}
        baseUrl={`/author/${author.username}/`}
      />
    </div>
  </main>
</Layout>