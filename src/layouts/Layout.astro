---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { settings } from '../data/settings';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	ogType?: 'website' | 'article' | 'profile';
}

const { title, description, image, ogType = 'website' } = Astro.props;
const siteTitle = title ? `${title} : ${settings.title}` : settings.title;
const siteDescription = description || settings.description;
// Astro.site is set in astro.config.mjs so this is always present at build time.
// Strip the trailing slash so downstream templates can always use `${siteUrl}/path`.
const siteUrl = (Astro.site?.toString() || 'https://infeeds.com').replace(/\/$/, '');
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();
const siteImage = image ? new URL(image, siteUrl).toString() : new URL(settings.logo, siteUrl).toString();

// Site-wide JSON-LD: identity (Organisation) + discovery (WebSite + SearchAction).
// SearchAction powers the sitelinks searchbox in Google SERPs.
const orgJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	'@id': `${siteUrl}#organization`,
	name: settings.title,
	url: siteUrl,
	logo: new URL(settings.logo, siteUrl).toString(),
	description: settings.description,
	sameAs: settings.social?.map((s) => s.link).filter(Boolean) ?? [],
};

const siteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': `${siteUrl}#website`,
	url: siteUrl,
	name: settings.title,
	description: settings.description,
	publisher: { '@id': `${siteUrl}#organization` },
	inLanguage: 'en',
	potentialAction: {
		'@type': 'SearchAction',
		target: {
			'@type': 'EntryPoint',
			urlTemplate: `${siteUrl}/blog/?q={search_term_string}`,
		},
		'query-input': 'required name=search_term_string',
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>
		<meta name="description" content={siteDescription} />
		<link rel="canonical" href={currentUrl} />
		<link rel="sitemap" type="application/xml" href="/sitemap.xml" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Display:wght@400;600;700&family=Noto+Serif:wght@400;700&display=swap" rel="stylesheet" />
		
		<!-- Ionicons -->
		<link href="https://unpkg.com/ionicons@4.2.2/dist/css/ionicons.min.css" rel="stylesheet" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={siteDescription} />
		<meta property="og:image" content={siteImage} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={currentUrl} />
		<meta property="twitter:title" content={siteTitle} />
		<meta property="twitter:description" content={siteDescription} />
		<meta property="twitter:image" content={siteImage} />

		<!-- Site-wide JSON-LD. Page-specific structured data goes in the named slot. -->
		<script is:inline type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
		<slot name="jsonld" />

		<script is:inline>
			if (localStorage.getItem("theme") === "dark") {
				document.documentElement.setAttribute("dark", "");
				document.documentElement.classList.add('dark-mode');
			}
		</script>

    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${settings.google_analytics}`}></script>
    <script is:inline define:vars={{ gaId: settings.google_analytics }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
	</head>
	<body>
		<div class="global-wrap">
			<Header />
			<main class="content">
				<slot />
			</main>
			<Footer />
		</div>

		<!-- Legacy /js/common.js and /js/scripts.js removed: the new
		     Header handles dropdown + theme + menu-toggle inline, and
		     search is fully client-side from /search-index.json. -->
	</body>
</html>