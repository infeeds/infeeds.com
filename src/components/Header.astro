---
// Modern compact header: text logo, primary nav (curated topic links),
// mega-menu "More" dropdown, search + theme toggle, contact mailto.
import { settings } from '../data/settings';
import { getTopCategories } from '../utils/categories';

// Curated primary nav. Order is intentional: readers come for the broad
// beats first (News, Tech, Business), the personal touch (Blog), then the
// long tail lives behind "More". Keep this list short — it sets the
// editorial tone of the brand.
const PRIMARY_SLUGS = ['news', 'tech', 'business'];

// Long tail that the mega menu offers when expanded.
const MEGA_MENU_SLUGS = [
  'health', 'science', 'politics', 'australia', 'finance',
  'travel', 'food', 'entertainment', 'lifestyle',
];

const topCategories = await getTopCategories(40);
const bySlug = new Map(topCategories.map((c) => [c.slug, c]));

const labelize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();

const primaryNav = PRIMARY_SLUGS
  .map((slug) => bySlug.get(slug))
  .filter(Boolean)
  .map((c) => ({ label: labelize(c.tag), href: `/tags/${c.slug}/` }));
primaryNav.push({ label: 'Blog', href: '/blog/' });

const used = new Set(PRIMARY_SLUGS);
const megaMenu = MEGA_MENU_SLUGS
  .map((slug) => bySlug.get(slug))
  .filter(Boolean)
  .filter((c) => !used.has(c.slug))
  .map((c) => ({ label: labelize(c.tag), href: `/tags/${c.slug}/` }));
---

<header class="header-mag">
  <div class="container">
    <div class="header-mag__inner">
      <a class="header-mag__brand" href="/" aria-label={settings.title}>
        {settings.logo && (
          <img class="header-mag__logo" src={settings.logo} alt={settings.title} loading="eager" />
        )}
        {!settings.logo && (
          <span class="header-mag__brand-mark">{settings.title}</span>
        )}
      </a>

      <nav class="header-mag__nav" id="primary-nav" aria-label="Primary">
        {primaryNav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        {megaMenu.length > 0 && (
          <div class="dropdown-mag dropdown-mag--mega" data-dropdown>
            <button type="button" class="nav-mag-trigger" data-dropdown-trigger aria-expanded="false">
              More <span class="arrow">&#9662;</span>
            </button>
            <div class="dropdown-mag-menu dropdown-mag-menu--mega" role="menu">
              <div class="dropdown-mag-menu__grid">
                {megaMenu.map((item) => (
                  <a href={item.href} role="menuitem">{item.label}</a>
                ))}
              </div>
              <a href="/tags/" class="dropdown-mag-menu__more" role="menuitem">All topics &rarr;</a>
            </div>
          </div>
        )}
      </nav>

      <div class="header-mag__actions">
        <a
          class="header-mag__icon-btn"
          href="mailto:exmgks@gmail.com?subject=Hello%20Infeeds"
          aria-label="Contact us"
          title="Contact us"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
        </a>
        <a
          class="header-mag__icon-btn"
          href="/search/"
          aria-label="Search"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
        </a>
        <button
          type="button"
          class="header-mag__icon-btn toggle-theme"
          aria-label="Toggle dark mode"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
        <button type="button" class="header-mag__icon-btn header-mag__menu-toggle" aria-label="Open menu" data-menu-toggle>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
      </div>
    </div>
  </div>
</header>
<!-- end header -->

<script is:inline>
  // Dropdown open/close on click, with click-outside-to-close.
  document.querySelectorAll('[data-dropdown]').forEach((drop) => {
    const trigger = drop.querySelector('[data-dropdown-trigger]');
    if (!trigger) return;
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = drop.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', String(isOpen));
      document.querySelectorAll('[data-dropdown]').forEach((other) => {
        if (other !== drop) {
          other.classList.remove('is-open');
          other.querySelector('[data-dropdown-trigger]')?.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('[data-dropdown].is-open').forEach((d) => {
      d.classList.remove('is-open');
      d.querySelector('[data-dropdown-trigger]')?.setAttribute('aria-expanded', 'false');
    });
  });

  // Mobile menu toggle
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const nav = document.getElementById('primary-nav');
  if (menuToggle && nav) {
    menuToggle.addEventListener('click', () => {
      nav.classList.toggle('is-open');
    });
  }

  // Dark mode: persists in localStorage, respects system preference on first load.
  const THEME_KEY = 'infeeds-theme';
  const root = document.documentElement;
  const setTheme = (mode) => {
    if (mode === 'dark') root.setAttribute('dark', '');
    else root.removeAttribute('dark');
  };
  const stored = (() => { try { return localStorage.getItem(THEME_KEY); } catch (e) { return null; } })();
  if (stored === 'dark' || stored === 'light') {
    setTheme(stored);
  } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
    setTheme('dark');
  }
  document.querySelectorAll('.toggle-theme').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const isDark = root.hasAttribute('dark');
      const next = isDark ? 'light' : 'dark';
      setTheme(next);
      try { localStorage.setItem(THEME_KEY, next); } catch (e) {}
    });
  });
</script>