---
interface Props {
  title: string;
  url: string;
  image?: string;
  description?: string;
  siteTitle: string;
}

const { title, url, image, description, siteTitle } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
const encodedImage = image ? encodeURIComponent(image) : '';
const encodedDescription = description ? encodeURIComponent(description) : '';
const encodedSiteTitle = encodeURIComponent(siteTitle);

// Plain anchor tags instead of inline `onclick="..."` — the inline
// string was confusing astro check's parser and flagged unreachable code.
const twitter = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const facebook = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const pinterest = `http://pinterest.com/pin/create/button/?url=${encodedUrl}&media=${encodedImage}&description=${encodedTitle}`;
const linkedin = `https://www.linkedin.com/shareArticle?mini=true&url=${encodedUrl}&title=${encodedTitle}&summary=${encodedDescription}&source=${encodedSiteTitle}`;
---

<div class="post__share">
  <div class="share__head">
    <div class="share__title">Share this:</div>
  </div>
  <ul class="share__list list-reset">
    <li class="share__item">
      <a class="share__link share__twitter"
        href={twitter}
        target="_blank"
        rel="noopener noreferrer nofollow"
        title="Share on Twitter"><i class="ion ion-logo-twitter"></i></a>
    </li>
    <li class="share__item">
      <a class="share__link share__facebook"
        href={facebook}
        target="_blank"
        rel="noopener noreferrer nofollow"
        title="Share on Facebook"><i class="ion ion-logo-facebook"></i></a>
    </li>
    <li class="share__item">
      <a class="share__link share__pinterest"
        href={pinterest}
        target="_blank"
        rel="noopener noreferrer nofollow"
        title="Share on Pinterest"><i class="ion ion-logo-pinterest"></i></a>
    </li>
    <li class="share__item">
      <a class="share__link share__linkedin"
        href={linkedin}
        target="_blank"
        rel="noopener noreferrer nofollow"
        title="Share on LinkedIn"><i class="ion ion-logo-linkedin"></i></a>
    </li>
  </ul>
</div>
