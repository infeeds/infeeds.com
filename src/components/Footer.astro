---
import { settings } from '../data/settings';
import AdUnit from './AdUnit.astro';

const { footer } = settings;
---

<AdUnit location="footer_ad" context="blog" />

<footer class="footer">
  <div class="container">
    <div class="row">
      <div class="col col-12">

        <div class="footer__inner is-border-top">
          <div class="row">
            <div class="col col-6 col-d-12">
              <div class="widget-footer widget-info">
                <h3 class="widget-info__title">{settings.title}</h3>
                <p class="widget-info__desc">{footer.description}</p>

                {settings.social && (
                  <div class="social">
                    <ul class="social__list list-reset">
                      {settings.social.map((social) => (
                        <li class="social__item">
                          <a class="social__link" href={social.link} target="_blank" rel="noopener" aria-label={`${social.icon} link`}>
                            <i class={`ion ion-logo-${social.icon}`}></i>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>

            <div class="col col-2 col-d-12">
              <div class="widget-footer widget-nav">
                <h3 class="widget-nav__title">Menu</h3>
                <ul class="widget-nav__list list-reset">
                  {footer.menu.map((item) => (
                    <li class="widget-nav__item">
                      <a href={item.url} class="widget-nav__link">{item.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

          </div>
        </div>

        <div class="footer__info">
          <div class="footer__info-box">
            <div class="copyright">{new Date().getFullYear()} &copy; <a href="/">{settings.title}</a>.</div>
            <div class="top" title="Top"><i class="ion ion-ios-arrow-round-up"></i></div>
          </div>
        </div>

      </div>
    </div>
  </div>
</footer>

<style>
  /* Local footer styles if needed, but mostly using global.css */
</style>
