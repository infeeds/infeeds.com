---
import { settings } from '../data/settings';

interface Props {
  location: 'header_ad' | 'sidebar_ad' | 'footer_ad';
  context: 'homepage' | 'blog';
}

const { location, context } = Astro.props;

// Ad slots are heterogeneous (`html` vs `image` vs `text`); the settings
// object's TS inference narrows `ad` to its specific shape, which makes
// cross-slot fields (start_date, image_url, text_title, …) fail type-
// checking. We cast to a single union that covers every slot shape.
type AdShape = {
  enabled: boolean;
  type: 'image' | 'html' | 'text';
  start_date?: string;
  duration_days?: number;
  image_url?: string;
  link_url?: string;
  alt_text?: string;
  html_content?: string;
  text_title?: string;
  text_content?: string;
  text_link_url?: string;
  text_link_label?: string;
};

const ad = settings.ads?.[context]?.[location] as AdShape | undefined;

const isActive = () => {
  if (!ad || !ad.enabled) return false;
  if (ad.start_date && ad.duration_days) {
    const startDate = new Date(ad.start_date);
    const endDate = new Date(startDate.getTime() + ad.duration_days * 86400000);
    const now = new Date();
    return now >= startDate && now < endDate;
  }
  return true;
};

const active = isActive();
---

{active && ad && (
  <div class={`ad-unit ad-unit--${location}`}>
    <span class="ad-unit__label">Advertisement</span>
    {ad.type === 'image' && ad.image_url && ad.link_url && (
      <a href={ad.link_url} target="_blank" rel="noopener sponsored">
        <img src={ad.image_url} alt={ad.alt_text || 'Advertisement'} />
      </a>
    )}

    {ad.type === 'html' && ad.html_content && (
      <Fragment set:html={ad.html_content} />
    )}

    {ad.type === 'text' && ad.text_content && (
      <div class="ad-unit--text">
        {ad.text_title && <h4>{ad.text_title}</h4>}
        <p>{ad.text_content}</p>
        {ad.text_link_url && ad.text_link_label && (
          <a href={ad.text_link_url} class="button" target="_blank" rel="noopener sponsored" style="color:rgb(22, 22, 216)">
            {ad.text_link_label}
          </a>
        )}
      </div>
    )}
  </div>
)}
