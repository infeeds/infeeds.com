---
// Auto-derived category section: shows the 4 most recent posts for a given tag.
// Renders nothing if the tag has fewer than `minPosts` entries.
//
// Consumes the same pre-built tag → posts index used by RelatedPosts and
// TrendingSidebar so the homepage doesn't pay N filter passes per category
// on every build. Slim entries are sufficient for the card template.
import { getPostsByTag } from '../utils/related';
import MagazineCard from './MagazineCard.astro';

interface Props {
  tag: string;
  count?: number;
  minPosts?: number;
}

const { tag, count = 4, minPosts = 2 } = Astro.props;

const tagLower = tag.toLowerCase();
const byTag = await getPostsByTag();
const posts = (byTag.get(tagLower) ?? []).slice(0, count);

const url = `/tags/${tagLower.replace(/\s+/g, '-')}/`;
const display = tag.charAt(0).toUpperCase() + tag.slice(1);
---

{posts.length >= minPosts && (
  <section class="section-mag">
    <div class="section-mag__head">
      <div>
        <span class="section-mag__kicker">More in</span>
        <h2 class="section-mag__title">{display}</h2>
      </div>
      <a href={url} class="section-mag__link">See all &rarr;</a>
    </div>
    <div class="cat-section__row">
      {posts.map((post) => <MagazineCard post={post} variant="grid" />)}
    </div>
  </section>
)}