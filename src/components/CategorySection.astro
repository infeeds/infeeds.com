---
// Auto-derived category section: shows the 4 most recent posts for a given tag.
// Renders nothing if the tag has fewer than `minPosts` entries.
import { getCollection } from 'astro:content';
import MagazineCard from './MagazineCard.astro';

interface Props {
  tag: string;
  count?: number;
  minPosts?: number;
}

const { tag, count = 4, minPosts = 2 } = Astro.props;

const posts = (await getCollection('posts', ({ data }) => {
  return (data.tags ?? []).map((t) => String(t).toLowerCase()).includes(tag.toLowerCase());
})).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const url = `/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`;
const display = tag.charAt(0).toUpperCase() + tag.slice(1);
---

{posts.length >= minPosts && (
  <section class="section-mag">
    <div class="section-mag__head">
      <div>
        <span class="section-mag__kicker">More in</span>
        <h2 class="section-mag__title">{display}</h2>
      </div>
      <a href={url} class="section-mag__link">See all &rarr;</a>
    </div>
    <div class="cat-section__row">
      {posts.slice(0, count).map((post) => (
        <MagazineCard post={post} variant="grid" />
      ))}
    </div>
  </section>
)}