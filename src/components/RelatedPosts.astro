---
// Magazine-style related posts. Shows posts that share tags with the
// current one, sorted by recency. Used inside the post-page sidebar.
import { getCollection } from 'astro:content';

interface Props {
  currentPostId: string;
  tags: string[];
  count?: number;
}

const { currentPostId, tags, count = 6 } = Astro.props;

const tagSet = new Set(tags.map((t) => String(t).toLowerCase()));
const allPosts = await getCollection('posts');
const relatedPosts = allPosts
  .filter((p) => p.id !== currentPostId && (p.data.tags ?? []).some((t) => tagSet.has(String(t).toLowerCase())))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, count);

const slugOf = (id: string) =>
  id.replace(/^\d{4}-\d{2}-\d{2}-/, '').replace(/\.(md|markdown|mdx)$/, '');

const dateLabel = (raw: unknown) => raw
  ? new Date(String(raw)).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
  : '';
---

{relatedPosts.length > 0 && (
  <div class="related-posts-mag">
    <h3 class="related-posts-mag__title">You may also like</h3>
    <ul class="related-posts-mag__list">
      {relatedPosts.map((post) => (
        <li>
          <a href={`/${slugOf(post.id)}/`} class="related-posts-mag__item">
            <div class="related-posts-mag__image">
              {post.data.image && <img src={post.data.image} alt={post.data.title} loading="lazy" />}
            </div>
            <div>
              <span class="related-posts-mag__tag">{post.data.tags?.[0] ?? ''}</span>
              <h4 class="related-posts-mag__heading">{post.data.title}</h4>
              <span class="related-posts-mag__meta">{dateLabel(post.data.date)}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}