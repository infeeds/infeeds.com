---
// Magazine-style related posts. Shows posts that share tags with the
// current one, sorted by recency. Used inside the post-page sidebar.
//
// The tag → posts index is built once per build via getPostsByTag() and
// reused for every post page; this avoids a full O(N) scan per render.
import { getRelatedSlim } from '../utils/related';

interface Props {
  currentPostId: string;
  tags: string[];
  count?: number;
}

const { currentPostId, tags, count = 6 } = Astro.props;

const relatedPosts = await getRelatedSlim(tags, currentPostId, count);

const slugOf = (id: string) =>
  id.replace(/^\d{4}-\d{2}-\d{2}-/, '').replace(/\.(md|markdown|mdx)$/, '');

const dateLabel = (raw: unknown) => raw
  ? new Date(String(raw)).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
  : '';
---

{relatedPosts.length > 0 && (
  <div class="related-posts-mag">
    <h3 class="related-posts-mag__title">You may also like</h3>
    <ul class="related-posts-mag__list">
      {relatedPosts.map((post) => (
        <li>
          <a href={`/${slugOf(post.id)}/`} class="related-posts-mag__item">
            <div class="related-posts-mag__image">
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  loading="lazy"
                  decoding="async"
                  width="80"
                  height="60"
                />
              )}
            </div>
            <div>
              {post.primaryTag && (
                <span class="related-posts-mag__tag">{post.primaryTag}</span>
              )}
              <h4 class="related-posts-mag__heading">{post.title}</h4>
              <span class="related-posts-mag__meta">{dateLabel(post.date)}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}