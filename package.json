{
  "name": "infeeds",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "sync-markdown": "for f in src/content/posts/*.markdown; do [ -f \"$f\" ] && mv \"$f\" \"${f%.markdown}.md\"; done || true",
    "cleanup": "node cleanup.js",
    "sync": "bun run sync-markdown && bun run cleanup",
    "check": "bunx --bun astro check",
    "dev": "bunx --bun astro dev",
    "build": "bun run check && bunx --bun astro build",
    "preview": "bunx --bun astro preview",
    "astro": "bunx --bun astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "astro": "^6.0.4",
    "gray-matter": "^4.0.3",
    "tinyglobby": "0.2.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "sass": "^1.98.0",
    "typescript": "^6.0.3"
  }
}